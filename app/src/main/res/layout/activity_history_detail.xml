<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- TITLE -->

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/Advertising_Data_Performance"
                android:textColor="@color/title_text"
                android:textStyle="bold"
                android:textSize="@dimen/title_size"
                android:padding="@dimen/padding_title"
                android:gravity="center"
                android:paddingBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="12dp"
                android:padding="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_result_card"
                android:elevation="6dp">
                <!-- SESSION INFO -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtSession"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Session ID : XXXXXXX"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/txtDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_date"
                        android:textColor="@color/text_primary"/>

                </LinearLayout>

                <!-- RANKING -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ranking"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/txtRanking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"/>

                <!-- KPI TABLE -->

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <TableLayout
                        android:id="@+id/tableKPI"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:stretchColumns="*">

                    </TableLayout>

                </HorizontalScrollView>

                <!-- CHART 1 -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Return Performance Comparison (ROI and ROAS)"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp"/>

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chartPerformance"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"/>

                <!-- CHART 2 -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Traffic Quality Comparison (CTR and CVR)"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp"/>

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chartTraffic"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"/>

                <!-- CHART 3 -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cost Per Click (CPC) Comparison"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp"/>

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chartCPC"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>